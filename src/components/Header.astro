        rounded-2xl py-3 px-8 font-normal text-white/60 text-xs hover:ring-white hover:-translate-y-[1px] transition-all duration-300"
	>
		<a href="#home" class="nav-link active">
			HOME

			<svg viewBox="0 0 512 512" aria-hidden="true">
				<path d="M0 0h512v512H0z" fill="none"></path>
				<path
					fill="currentColor"
					d="m208 512l-52.38-139.62L16 320l139.62-52.38L208 128l52.38 139.62L400 320l-139.62 52.38ZM88 176l-23.57-64.43L0 88l64.43-23.57L88 0l23.57 64.43L176 88l-64.43 23.57Zm312 80l-31.11-80.89L288 144l80.89-31.11L400 32l31.11 80.89L512 144l-80.89 31.11Z"
				></path>
			</svg>
		</a>

		<a href="#projects" class="nav-link">
			PROJECTS

			<svg viewBox="0 0 512 512" aria-hidden="true">
				<path
					fill="currentColor"
					d="m208 512l-52.38-139.62L16 320l139.62-52.38L208 128l52.38 139.62L400 320l-139.62 52.38ZM88 176l-23.57-64.43L0 88l64.43-23.57L88 0l23.57 64.43L176 88l-64.43 23.57Zm312 80l-31.11-80.89L288 144l80.89-31.11L400 32l31.11 80.89L512 144l-80.89 31.11Z"
				></path>
			</svg>
		</a>

		<a href="#about" class="nav-link">
			ABOUT

			<svg viewBox="0 0 512 512" aria-hidden="true">
				<path
					fill="currentColor"
					d="m208 512l-52.38-139.62L16 320l139.62-52.38L208 128l52.38 139.62L400 320l-139.62 52.38ZM88 176l-23.57-64.43L0 88l64.43-23.57L88 0l23.57 64.43L176 88l-64.43 23.57Zm312 80l-31.11-80.89L288 144l80.89-31.11L400 32l31.11 80.89L512 144l-80.89 31.11Z"
				></path>
			</svg>
		</a>

		<a href="#services" class="nav-link">
			SERVICES

			<svg viewBox="0 0 512 512" aria-hidden="true">
