					fill="currentColor"
					d="m208 512l-52.38-139.62L16 320l139.62-52.38L208 128l52.38 139.62L400 320l-139.62 52.38ZM88 176l-23.57-64.43L0 88l64.43-23.57L88 0l23.57 64.43L176 88l-64.43 23.57Zm312 80l-31.11-80.89L288 144l80.89-31.11L400 32l31.11 80.89L512 144l-80.89 31.11Z"
				></path>
			</svg>
		</a>
	</nav>

	<button
		class="contact-button bg-black rounded-2xl py-3 px-6
    text-white/80 font-normal text-xs ring ring-inset ring-white/60
       hover:ring-white hover:-translate-y-[1px] hover:text-white transition-all
            duration-300"
		>CONTACT</button
	>
</header>

<style>
	.nav-link {
		position: relative;
		transition:
			opacity 500ms ease,
			transform 500ms ease;
	}

	.nav-link svg {
		position: absolute;
		top: 50%;
		right: -0.8rem;
		width: 0.85rem;
		height: 0.85rem;
		color: white;
		opacity: 0;
		transform: translateY(-50%) translateX(0%) scale(1) rotate(-20deg);
		pointer-events: none;

		transition:
			opacity 500ms ease,
			transform 500ms ease;
	}

	.nav-link.active {
		color: white;
		transform: translateX(-0.4rem);
	}

	.nav-link.active svg {
		opacity: 1;
		transform: translateY(-50%) translateX(50%) scale(1) rotate(0deg);
	}
</style>

<script>
	const sections = document.querySelectorAll("section[id], main[id]");
	const navLinks = document.querySelectorAll(".nav-link");

	const observer = new IntersectionObserver(
		(entries) => {
			const visibleSection = entries.find((entry) => entry.isIntersecting);

			if (!visibleSection) return;

			navLinks.forEach((link) => {
				const isActive =
					link.getAttribute("href") === `#${visibleSection.target.id}`;

				link.classList.toggle("active", isActive);
			});
		},
		{
			rootMargin: "-40% 0px -50% 0px",
			threshold: 0,
		},
	);

	sections.forEach((section) => observer.observe(section));
</script>
