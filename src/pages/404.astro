---
import Layout from "../layouts/Layout.astro";
---

<Layout siteTitle="Kaede Project - Not Found">
	<div
		class="w-full flex flex-col items-center justify-center min-h-screen text-center"
	>
		<svg
			xmlns="http://www.w3.org/2000/svg"
			width="4em"
			height="4em"
			viewBox="0 0 512 512"
		>
			<path d="M0 0h512v512H0z" fill="none"></path>
			<path
				fill="#fff"
				d="m208 512l-52.38-139.62L16 320l139.62-52.38L208 128l52.38 139.62L400 320l-139.62 52.38ZM88 176l-23.57-64.43L0 88l64.43-23.57L88 0l23.57 64.43L176 88l-64.43 23.57Zm312 80l-31.11-80.89L288 144l80.89-31.11L400 32l31.11 80.89L512 144l-80.89 31.11Z"
			></path>
		</svg>

		<h2 class="mt-2">
			Ahhh, soemething <span class="text-6xl font-instrument italic"
				>went wrong :(</span
			>
		</h2>

		<p class="mt-4 text-sm font-thin text-white/80">
			We couldn't find what you were looking for.
		</p>

		<div class="mt-6 flex flex-row gap-4">
			<a
				href="/"
				class="contact-button bg-white/80 rounded-2xl py-3 px-6
                text-black font-normal text-xs ring ring-inset ring-black
                     hover:ring-black hover:-translate-y-[1px] hover:text-black transition-all
                        hover:bg-white duration-300"
			>
				BACK TO HOME
			</a>

			<a
				href="#"
				class="contact-button bg-black rounded-2xl py-3 px-6
                text-white/80 font-normal text-xs ring ring-inset ring-white/60
                     hover:ring-white hover:-translate-y-[1px] hover:text-white transition-all
                        duration-300"
			>
				CONTACT
			</a>
		</div>
	</div>
</Layout>
